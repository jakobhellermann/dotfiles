{
  // theme
  "theme": "VSCode Dark Modern",
  "ui_font_family": ".ZedSans", // default
  "buffer_font_family": "Recursive Mono Linear Static",

  // behaviour
  "autosave": "on_focus_change",
  "extend_comment_on_newline": false,
  "format_on_save": "on",
  "vim_mode": true,

  // remove unwanted features
  "title_bar": {
    "show_sign_in": false,
  },
  "auto_update": false,
  "terminal": {
    "button": false,
    "shell": "system",
    "detect_venv": "off",
    "toolbar": {
      "breadcrumbs": false,
    },
    "dock": "bottom",
    "option_as_meta": true,
  },
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
    },
    "button": true,
    "enabled": true,
  },
  "edit_predictions": {
    "provider": null,
  },
  "notification_panel": {
    "button": false,
  },
  "collaboration_panel": {
    "button": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },

  // UI
  "indent_guides": {
    "enabled": false,
  },
  "cursor_blink": false,
  "gutter": {
    "folds": true,
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.settings",
    "**/.venv",
    "**/.jj",
    "**/__pycache__",
    // "**/.jj",
    "**/.idea",
  ],

  // language config
  "file_types": {
    // "JSON": [".prettierrc"]
  },
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "enabled": true,
    },
  },

  "languages": {
    // disable format on save
    "XML": { "format_on_save": "off" },
    "Beancount": {
      "tab_size": 2,
      "format_on_save": "off",
    },
    "Java": { "format_on_save": "off" },
    "C": { "format_on_save": "off" },
    "C++": { "format_on_save": "off" },

    // specify lsp
    "Nix": {
      "language_servers": ["nixd", "!nil"],
    },
    "Python": {
      "formatter": {
        "external": {
          "command": "ruff",
          "arguments": ["format", "-"],
        },
      },
      "language_servers": ["ty", "!basedpyright", "..."],
    },

    // prefer oxc over prettier
    "CSS": {
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "HTML": {
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "JavaScript": {
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
        {
          "code_action": "source.fixAll.oxc",
        },
      ],
    },
    "JSON": {
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "Markdown": {
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "TypeScript": {
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "TSX": {
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "YAML": {
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },

    "jjmagit": {
      "semantic_tokens": "full",
      "document_folding_ranges": "on",
    },
  },

  "lsp": {
    "cargo-tom": {
      "initialization_options": {
        "offline": false,
      },
    },
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemas": {
            "https://raw.githubusercontent.com/kaitai-io/ksy_schema/master/ksy_schema.json": [
              "*.ksy",
            ],
          },
        },
      },
    },
    /*"oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": null,
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "typeAware": true,
          "unusedDisableDirectives": "deny",
        },
      },
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "configPath": null,
          "run": "onSave",
        },
      },
    },*/
  },

  "semantic_tokens": "off",
  // "document_folding_ranges": "",

  // credentials
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": "ctx7sk-19044bbc-5566-4a7d-84dc-2ec9026be71c",
      },
    },
  },

  "global_lsp_settings": {
    "semantic_token_rules": [
      {
        "token_type": "error",
        "font_weight": "bold",
        "foreground_color": "#ffffff",
      },
      {
        "token_type": "error_source",
        "foreground_color": "#ffffff",
      },
      {
        "token_type": "warning",
        "font_weight": "bold",
        "foreground_color": "#ffffff",
      },
      {
        "token_type": "hint",
        "foreground_color": "#ffffff",
      },
      {
        "token_type": "conflict_description",
        "foreground_color": "#808000",
      },
      {
        "token_type": "commit_id",
        "foreground_color": "#000080",
      },
      {
        "token_type": "change_id",
        "foreground_color": "#800080",
      },
      {
        "token_type": "prefix",
        "font_weight": "bold",
        "foreground_color": "#cc00ff",
      },
      {
        "token_type": "rest",
        "foreground_color": "#808080",
      },
      {
        "token_type": "change_offset",
        "font_weight": "bold",
      },
      {
        "token_type": "author",
        "foreground_color": "#808000",
      },
      {
        "token_type": "committer",
        "foreground_color": "#808000",
      },
      {
        "token_type": "timestamp",
        "foreground_color": "#008080",
      },
      {
        "token_type": "working_copies",
        "foreground_color": "#008000",
      },
      {
        "token_type": "bookmark",
        "foreground_color": "#800080",
      },
      {
        "token_type": "bookmarks",
        "foreground_color": "#800080",
      },
      {
        "token_type": "local_bookmarks",
        "foreground_color": "#800080",
      },
      {
        "token_type": "remote_bookmarks",
        "foreground_color": "#800080",
      },
      {
        "token_type": "tag",
        "foreground_color": "#800080",
      },
      {
        "token_type": "tags",
        "foreground_color": "#800080",
      },
      {
        "token_type": "git_ref",
        "foreground_color": "#008000",
      },
      {
        "token_type": "git_refs",
        "foreground_color": "#008000",
      },
      {
        "token_type": "git_head",
        "foreground_color": "#008000",
      },
      {
        "token_type": "divergent",
        "foreground_color": "#800080",
      },
      {
        "token_type": "conflict",
        "foreground_color": "#800000",
      },
      {
        "token_type": "empty",
        "foreground_color": "#008000",
      },
      {
        "token_type": "placeholder",
        "foreground_color": "#d05000",
      },
      {
        "token_type": "separator",
        "foreground_color": "#808080",
      },
      {
        "token_type": "elided",
        "foreground_color": "#808080",
      },
      {
        "token_type": "root",
        "foreground_color": "#008000",
      },
      {
        "token_type": "working_copy",
        "font_weight": "bold",
      },
      {
        "token_type": "snapshot",
        "foreground_color": "#00af50",
      },
      {
        "token_type": "name",
        "foreground_color": "#cccc00",
      },
    ],
  },
}
